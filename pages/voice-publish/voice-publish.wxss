/* 意见反馈页样式 */

.feedback-form {
  margin: 0 24rpx;
}

.form-group {
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid var(--md-outline-variant);
}

.form-group:last-child {
  border-bottom: none;
}

.form-label {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--md-on-surface);
  margin-bottom: 16rpx;
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
}

.form-picker-text {
  font-size: 30rpx;
  color: var(--md-on-surface);
}

.form-textarea {
  width: 100%;
  height: 240rpx;
  font-size: 28rpx;
  color: var(--md-on-surface);
  line-height: 1.6;
  padding: 16rpx;
  background: var(--md-surface-container-highest);
  border-radius: 8rpx 8rpx 0 0;
  box-sizing: border-box;
}

.form-counter {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: var(--md-on-surface-variant);
  margin-top: 8rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  font-size: 28rpx;
  color: var(--md-on-surface);
  padding: 0 16rpx;
  background: var(--md-surface-container-highest);
  border-radius: 8rpx 8rpx 0 0;
  box-sizing: border-box;
}

.feedback-actions {
  margin: 48rpx 24rpx;
}

.ios-btn--disabled {
  opacity: 0.6;
  pointer-events: none;
}
