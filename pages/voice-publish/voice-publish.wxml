<nav-bar title="发布诉求" showBack="{{true}}" />

<view class="page-container">
  <!-- 诉求表单 -->
  <view class="feedback-form ios-card">
    <view class="form-group">
      <text class="form-label">诉求类型</text>
      <picker mode="selector" range="{{types}}" value="{{typeIndex}}" bindchange="onTypeChange">
        <view class="form-picker">
          <text class="form-picker-text">{{types[typeIndex]}}</text>
          <view class="ios-list-item__arrow"></view>
        </view>
      </picker>
    </view>

    <view class="form-group">
      <text class="form-label">诉求内容</text>
      <textarea class="form-textarea" placeholder="请详细描述您的诉求，如物品规格、出发时间、目的地等..." maxlength="500" bindinput="onContentInput" value="{{content}}"></textarea>
      <text class="form-counter">{{content.length}}/500</text>
    </view>

    <view class="form-group">
      <text class="form-label">联系方式（选填）</text>
      <input class="form-input" placeholder="手机号或微信号，方便他人联系您" bindinput="onContactInput" value="{{contact}}" />
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="feedback-actions">
    <view class="ios-btn ios-btn--primary {{submitting ? 'ios-btn--disabled' : ''}}" bindtap="onSubmit">
      {{submitting ? '发布中...' : '发布诉求'}}
    </view>
  </view>
</view>
