<view class="page-container">
  <view class="payment-list" wx:if="{{paymentList.length > 0}}">
    <view class="payment-card ios-card" wx:for="{{paymentList}}" wx:key="id" data-id="{{item.id}}" bindtap="onPaymentTap">
      <view class="payment-header">
        <view class="payment-tag-group">
          <text class="ios-tag ios-tag--{{item.tagType}}">{{item.tag}}</text>
          <text wx:if="{{item.hot}}" class="hot-badge">HOT</text>
        </view>
        <text class="payment-date">{{item.date}}</text>
      </view>
      <text class="payment-title">{{item.title}}</text>
      <text class="payment-summary">{{item.summary}}</text>
      <view class="payment-arrow"></view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{paymentList.length === 0}}">
    <text class="empty-state__text">暂无缴费指南</text>
  </view>
</view>
