/* 缴费知识页样式 */

.payment-list {
  padding: 24rpx 24rpx 32rpx;
}

.payment-card {
  padding: 24rpx;
  margin-bottom: 16rpx;
  position: relative;
}

.payment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.payment-tag-group {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.hot-badge {
  padding: 4rpx 12rpx;
  border-radius: var(--radius-pill);
  background: var(--md-primary);
  color: var(--md-on-primary);
  font-size: 20rpx;
  font-weight: 700;
}

.payment-date {
  font-size: 22rpx;
  color: var(--md-on-surface-variant);
}

.payment-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--md-on-surface);
  line-height: 1.4;
  display: block;
  margin-bottom: 8rpx;
}

.payment-summary {
  font-size: 26rpx;
  color: var(--md-on-surface-variant);
  line-height: 1.5;
  display: block;
  padding-right: 40rpx;
}

.payment-arrow {
  position: absolute;
  right: 24rpx;
  top: 50%;
  width: 16rpx;
  height: 16rpx;
  border-top: 3rpx solid var(--md-outline-variant);
  border-right: 3rpx solid var(--md-outline-variant);
  transform: translateY(-50%) rotate(45deg);
}
