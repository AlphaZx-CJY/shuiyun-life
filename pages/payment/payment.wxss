/* 缴费知识页样式 */

.payment-list {
  padding: 24rpx 24rpx 32rpx;
}

.payment-card {
  padding: 28rpx;
  margin-bottom: 16rpx;
  position: relative;
}

.payment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.payment-tag-group {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.hot-badge {
  padding: 4rpx 12rpx;
  border-radius: var(--radius-pill);
  background: #0071e3;
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: 700;
}

.payment-date {
  font-size: 22rpx;
  color: var(--ios-light-gray);
}

.payment-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1D1D1F;
  line-height: 1.4;
  display: block;
  margin-bottom: 12rpx;
}

.payment-summary {
  font-size: 26rpx;
  color: var(--ios-gray);
  line-height: 1.5;
  display: block;
  padding-right: 40rpx;
}

.payment-arrow {
  position: absolute;
  right: 28rpx;
  top: 50%;
  width: 16rpx;
  height: 16rpx;
  border-top: 3rpx solid #D2D2D7;
  border-right: 3rpx solid #D2D2D7;
  transform: translateY(-50%) rotate(45deg);
}
