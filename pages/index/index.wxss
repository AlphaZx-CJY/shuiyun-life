/* 首页样式 */

.header {
  padding: 48rpx 32rpx 24rpx;
  background: var(--ios-bg);
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1D1D1F;
  letter-spacing: -0.5rpx;
}

.header-subtitle {
  font-size: 26rpx;
  color: #86868B;
  margin-top: 8rpx;
}

/* Banner */
.banner-section {
  margin: 0 24rpx;
}

.banner-swiper {
  height: 320rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
}

.banner-item {
  position: relative;
  width: 100%;
  height: 100%;
}

.banner-image {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #F5F5F7 0%, #FFFFFF 100%);
}

.banner-mask {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 80rpx 24rpx 24rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, transparent 100%);
}

.banner-title {
  color: #1D1D1F;
  font-size: 32rpx;
  font-weight: 600;
}

/* 快捷入口 */
.quick-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  background: var(--ios-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  transition: transform 0.2s;
}

.quick-item:active {
  transform: scale(0.96);
}

.quick-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.quick-icon-text {
  font-size: 48rpx;
}

.quick-label {
  font-size: 24rpx;
  color: #86868B;
  font-weight: 500;
}

/* 分区头部 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 16rpx;
}

.section-more {
  font-size: 24rpx;
  color: #1D1D1F;
  font-weight: 500;
}

/* 新闻项 */
.news-item {
  display: flex;
  align-items: center;
  padding: 24rpx 24rpx;
  position: relative;
}

.news-item::after {
  content: '';
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 0;
  height: 1rpx;
  background: var(--ios-separator);
  transform: scaleY(0.5);
}

.news-item:last-child::after {
  display: none;
}

.news-content {
  flex: 1;
  min-width: 0;
  margin-right: 16rpx;
}

.news-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.news-tag {
  flex-shrink: 0;
}

.news-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1D1D1F;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.news-summary {
  font-size: 24rpx;
  color: var(--ios-gray);
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.news-meta {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
}

.news-source, .news-date {
  font-size: 22rpx;
  color: var(--ios-light-gray);
}

/* 便民项 */
.schedule-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  position: relative;
}

.schedule-item::after {
  content: '';
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 0;
  height: 1rpx;
  background: var(--ios-separator);
  transform: scaleY(0.5);
}

.schedule-item:last-child::after {
  display: none;
}

.schedule-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.schedule-dot--upcoming {
  background: #1D1D1F;
}

.schedule-dot--ongoing {
  background: #8E8E93;
}

.schedule-dot--ended {
  background: #F5F5F7;
}

.schedule-content {
  flex: 1;
  min-width: 0;
}

.schedule-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #1D1D1F;
  display: block;
}

.schedule-info {
  font-size: 24rpx;
  color: var(--ios-gray);
  margin-top: 4rpx;
  display: block;
}
