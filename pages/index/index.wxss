/* 首页样式 — Apple Design */

/* 头部 */
.header {
  padding: 64rpx 40rpx 32rpx;
  background: var(--ios-bg);
}

.header-title {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--md-on-surface);
  letter-spacing: -0.8rpx;
  line-height: 1.2;
}

.header-subtitle {
  font-size: 28rpx;
  color: var(--md-on-surface-variant);
  margin-top: 12rpx;
  font-weight: 400;
}

/* Banner */
.banner-section {
  margin: 0 32rpx;
  height: 340rpx;
}






/* 快捷入口 */
.section-quick {
  margin-top: 32rpx;
  margin-bottom: 32rpx;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  padding: 0;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 0 22rpx;
  background: var(--md-surface-container);
  border-radius: var(--radius-md);
  border: none;
  box-shadow: none;
  transition: transform 0.2s cubic-bezier(0.25, 0.1, 0.25, 1), opacity 0.2s;
}

.quick-item:active {
  transform: scale(0.96);
  opacity: 0.85;
}

.quick-icon-wrap {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: var(--md-primary-container);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 14rpx;
  box-shadow: none;
}

.quick-icon-emoji {
  font-size: 40rpx;
  line-height: 1;
}

.quick-label {
  font-size: 24rpx;
  color: var(--md-on-surface);
  font-weight: 500;
}

/* 班车 Banner 卡片 */
.banner-shuttle-card {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, var(--md-primary) 0%, #354E16 100%);
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
  position: relative;
  overflow: hidden;
}

.banner-shuttle-card::before {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 50%;
}

.banner-shuttle-card::after {
  content: '';
  position: absolute;
  bottom: -40rpx;
  left: -40rpx;
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 50%;
}

.banner-shuttle-content {
  display: flex;
  flex-direction: column;
  z-index: 1;
}

.banner-shuttle-tag {
  display: inline-flex;
  align-self: flex-start;
  padding: 6rpx 18rpx;
  background: rgba(255, 255, 255, 0.18);
  border-radius: var(--radius-pill);
  font-size: 22rpx;
  font-weight: 500;
  color: var(--md-on-primary);
  margin-bottom: 16rpx;
  backdrop-filter: blur(8rpx);
}

.banner-shuttle-route {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--md-on-primary);
  letter-spacing: 0.2rpx;
  margin-bottom: 16rpx;
}

.banner-shuttle-time-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.banner-shuttle-time {
  font-size: 56rpx;
  font-weight: 300;
  color: var(--md-on-primary);
  letter-spacing: -1rpx;
  line-height: 1;
}

.banner-shuttle-status {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-pill);
  font-size: 22rpx;
  font-weight: 500;
}

.banner-shuttle-status.soon {
  background: rgba(255, 255, 255, 0.25);
  color: var(--md-on-primary);
}

.banner-shuttle-status.upcoming {
  background: rgba(255, 255, 255, 0.15);
  color: rgba(255, 255, 255, 0.9);
}

.banner-shuttle-status.passed {
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.6);
}

.banner-shuttle-arrow {
  z-index: 1;
}

.shuttle-arrow-icon {
  width: 16rpx;
  height: 16rpx;
  border-top: 3rpx solid rgba(255, 255, 255, 0.6);
  border-right: 3rpx solid rgba(255, 255, 255, 0.6);
  transform: rotate(45deg);
}

/* 分区头部 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--md-on-surface);
  letter-spacing: -0.2rpx;
}

.section-more {
  font-size: 24rpx;
  color: var(--md-primary);
  font-weight: 500;
}

/* 社区通知 */
.notice-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  position: relative;
}

.notice-item::after {
  content: '';
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  bottom: 0;
  height: 1rpx;
  background: var(--ios-separator);
  transform: scaleY(0.5);
}

.notice-item:last-child::after {
  display: none;
}

.notice-tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-pill);
  font-size: 20rpx;
  font-weight: 600;
  background: var(--md-error-container);
  color: var(--md-error);
  margin-right: 20rpx;
  flex-shrink: 0;
}

.notice-title {
  flex: 1;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--md-on-surface);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  letter-spacing: -0.2rpx;
}

/* 活动项 */
.schedule-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  position: relative;
}

.schedule-item::after {
  content: '';
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  bottom: 0;
  height: 1rpx;
  background: var(--ios-separator);
  transform: scaleY(0.5);
}

.schedule-item:last-child::after {
  display: none;
}

.schedule-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.schedule-dot--upcoming {
  background: var(--ios-accent);
}

.schedule-dot--ongoing {
  background: var(--md-outline);
}

.schedule-dot--ended {
  background: var(--md-outline-variant);
}

.schedule-content {
  flex: 1;
  min-width: 0;
}

.schedule-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--md-on-surface);
  display: block;
  letter-spacing: -0.2rpx;
}

.schedule-info {
  font-size: 24rpx;
  color: var(--md-on-surface-variant);
  margin-top: 6rpx;
  display: block;
  font-weight: 400;
}

/* Custom tab-bar padding */
.page-container {
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}
