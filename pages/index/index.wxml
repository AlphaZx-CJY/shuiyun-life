<view class="page-container">
  <!-- 头部 -->
  <view class="header">
    <view class="header-title">新长宁水韵名邸</view>
    <view class="header-subtitle">让生活更便捷</view>
  </view>

  <!-- 班车信息卡片 -->
  <view class="banner-section" wx:if="{{nextShuttle}}" bindtap="onShuttleBannerTap">
    <view class="banner-shuttle-card">
      <view class="banner-shuttle-content">
        <view class="banner-shuttle-tag">社区班车</view>
        <text class="banner-shuttle-route">{{routeName}}</text>
        <view class="banner-shuttle-time-wrap">
          <block wx:if="{{nextShuttle.status === 'passed'}}">
            <text class="banner-shuttle-status passed">今日已结束</text>
          </block>
          <block wx:else>
            <text class="banner-shuttle-time">{{nextShuttle.time}}</text>
            <text class="banner-shuttle-status {{nextShuttle.status}}">{{nextShuttle.status === 'soon' ? '即将发车' : '下一班'}}</text>
          </block>
        </view>
      </view>
      <view class="banner-shuttle-arrow">
        <view class="shuttle-arrow-icon"></view>
      </view>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="ios-section section-quick">
    <view class="quick-grid">
      <view class="quick-item" wx:for="{{quickEntries}}" wx:key="id" data-path="{{item.path}}" bindtap="onEntryTap">
        <view class="quick-icon-wrap">
          <text class="quick-icon-emoji">{{item.icon}}</text>
        </view>
        <text class="quick-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <!-- 社区通知 -->
  <view class="ios-section">
    <view class="section-header">
      <text class="section-title">社区通知</text>
      <text class="section-more" bindtap="onMoreNoticeTap">查看更多</text>
    </view>
    <view class="ios-card">
      <view class="notice-item" wx:for="{{noticeNews}}" wx:key="id" data-id="{{item.id}}" bindtap="onNoticeTap">
        <text class="notice-tag">{{item.tag}}</text>
        <text class="notice-title">{{item.title}}</text>
        <view class="ios-list-item__arrow"></view>
      </view>
      <view class="empty-state" wx:if="{{noticeNews.length === 0}}">
        <text class="empty-state__text">暂无社区通知</text>
      </view>
    </view>
  </view>

  <!-- 最近活动 -->
  <view class="ios-section">
    <view class="section-header">
      <text class="section-title">最近活动</text>
      <text class="section-more" bindtap="onMoreScheduleTap">查看全部</text>
    </view>
    <view class="ios-card">
      <view class="schedule-item" wx:for="{{recentSchedules}}" wx:key="id" data-id="{{item.id}}" bindtap="onScheduleTap">
        <view class="schedule-dot schedule-dot--{{item.status}}"></view>
        <view class="schedule-content">
          <text class="schedule-title">{{item.title}}</text>
          <text class="schedule-info"><text class="schedule-date">{{item.dateLabel}}</text> · {{item.time}} · {{item.location}}</text>
        </view>
      </view>
      <view class="empty-state" wx:if="{{recentSchedules.length === 0}}">
        <text class="empty-state__text">暂无近期活动</text>
      </view>
    </view>
  </view>
</view>
