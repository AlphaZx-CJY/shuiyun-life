/* 资讯页样式 */

.category-bar {
  background: var(--ios-bg);
  padding: 16rpx 0;
  position: sticky;
  top: 0;
  z-index: 10;
}

.category-scroll {
  white-space: nowrap;
}

.category-list {
  display: inline-flex;
  padding: 0 24rpx;
  gap: 16rpx;
}

.category-item {
  padding: 12rpx 28rpx;
  border-radius: var(--radius-pill);
  background: var(--ios-card);
  transition: all 0.2s;
}

.category-item--active {
  background: #1D1D1F;
}

.category-text {
  font-size: 26rpx;
  color: #86868B;
  font-weight: 500;
}

.category-item--active .category-text {
  color: #FFFFFF;
}

/* 新闻卡片 */
.news-list {
  padding: 8rpx 24rpx 32rpx;
}

.news-card {
  display: flex;
  background: var(--ios-card);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
}

.news-card__content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.news-card__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.news-card__date {
  font-size: 22rpx;
  color: var(--ios-light-gray);
}

.news-card__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1D1D1F;
  line-height: 1.4;
  margin-bottom: 8rpx;
}

.news-card__summary {
  font-size: 26rpx;
  color: var(--ios-gray);
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  margin-bottom: 12rpx;
}

.news-card__footer {
  margin-top: auto;
}

.news-card__source {
  font-size: 22rpx;
  color: var(--ios-light-gray);
}

.news-card__cover {
  width: 200rpx;
  height: 160rpx;
  border-radius: var(--radius-sm);
  margin-left: 20rpx;
  flex-shrink: 0;
  background: var(--ios-bg);
}
