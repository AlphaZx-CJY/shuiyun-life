/* 使用指南列表页样式 */

.guide-list {
  padding: 24rpx 24rpx 32rpx;
}

.guide-card {
  padding: 28rpx;
  margin-bottom: 16rpx;
  position: relative;
}

.guide-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.guide-date {
  font-size: 22rpx;
  color: var(--ios-light-gray);
}

.guide-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--md-on-surface);
  line-height: 1.4;
  display: block;
  padding-right: 40rpx;
}

.guide-arrow {
  position: absolute;
  right: 28rpx;
  top: 50%;
  width: 16rpx;
  height: 16rpx;
  border-top: 3rpx solid var(--md-outline-variant);
  border-right: 3rpx solid var(--md-outline-variant);
  transform: translateY(-50%) rotate(45deg);
}
