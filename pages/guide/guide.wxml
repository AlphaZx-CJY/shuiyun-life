<nav-bar title="使用指南" showBack="{{true}}" />

<view class="page-container">
  <view class="guide-list" wx:if="{{guideList.length > 0}}">
    <view class="guide-card ios-card" wx:for="{{guideList}}" wx:key="id" data-id="{{item.id}}" bindtap="onGuideTap">
      <view class="guide-header">
        <text class="ios-tag ios-tag--blue">{{item.tag}}</text>
        <text class="guide-date">{{item.date}}</text>
      </view>
      <text class="guide-title">{{item.title}}</text>
      <view class="guide-arrow"></view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{guideList.length === 0}}">
    <text class="empty-state__text">暂无使用指南</text>
  </view>
</view>
