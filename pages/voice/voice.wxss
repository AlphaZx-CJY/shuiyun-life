/* 邻里互助列表页 */

.voice-list {
  padding: 0 24rpx;
}

.voice-card {
  margin-bottom: 24rpx;
  padding: 32rpx;
  position: relative;
}

.voice-card--expired {
  opacity: 0.6;
}

.voice-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.voice-tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 18rpx;
  background: var(--md-primary-container);
  color: var(--md-on-primary-container);
  border-radius: var(--radius-pill);
  font-size: 24rpx;
  font-weight: 500;
}

.voice-status {
  font-size: 24rpx;
  color: var(--md-error);
}

.voice-deadline {
  font-size: 24rpx;
  color: var(--md-on-surface-variant);
}

.voice-content {
  font-size: 30rpx;
  color: var(--md-on-surface);
  line-height: 1.6;
  display: block;
  margin-bottom: 16rpx;
}

.voice-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.voice-date {
  font-size: 24rpx;
  color: var(--md-on-surface-variant);
}

.voice-contact {
  font-size: 24rpx;
  color: var(--md-primary);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
}

.empty-state__text {
  font-size: 30rpx;
  color: var(--md-on-surface-variant);
  margin-bottom: 12rpx;
}

.empty-state__hint {
  font-size: 26rpx;
  color: var(--md-on-surface-variant);
}

/* 浮动发布按钮 */
.voice-float-btn {
  position: fixed;
  right: 32rpx;
  bottom: calc(32rpx + env(safe-area-inset-bottom));
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: var(--md-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.voice-float-btn:active {
  transform: scale(0.92);
}

.voice-float-icon {
  font-size: 48rpx;
  color: var(--md-on-primary);
  font-weight: 300;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}
