/* 发布闲置页样式 */

.image-upload-row {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 16rpx;
}

.image-thumb-wrap {
  position: relative;
  width: 160rpx;
  height: 160rpx;
}

.image-thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-sm);
  background: var(--ios-bg);
}

.image-remove {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 36rpx;
  height: 36rpx;
  background: #F5F5F7;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.image-remove-icon {
  color: #1D1D1F;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1;
}

.image-upload-btn {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-sm);
  border: 2rpx dashed var(--ios-light-gray);
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--ios-bg);
}

.image-upload-plus {
  font-size: 56rpx;
  color: var(--ios-light-gray);
  font-weight: 300;
  line-height: 1;
}

.form-optional {
  font-size: 24rpx;
  color: var(--ios-light-gray);
  font-weight: 400;
}

.form-card {
  margin: 24rpx;
  padding: 8rpx 24rpx;
}

.form-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--ios-separator);
}

.form-item--last {
  border-bottom: none;
}

.form-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #1D1D1F;
  display: block;
  margin-bottom: 16rpx;
}

.form-required {
  color: #86868B;
}

.form-input {
  font-size: 30rpx;
  color: #1D1D1F;
  height: 56rpx;
  line-height: 56rpx;
}

.form-price-input {
  display: flex;
  align-items: center;
}

.form-price-symbol {
  font-size: 30rpx;
  color: #1D1D1F;
  font-weight: 600;
  margin-right: 12rpx;
}

.form-textarea {
  font-size: 30rpx;
  color: #1D1D1F;
  width: 100%;
  height: 160rpx;
  line-height: 1.6;
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.form-picker-text {
  font-size: 30rpx;
  color: #1D1D1F;
}

.form-actions {
  display: flex;
  gap: 24rpx;
  margin: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.form-btn {
  flex: 1;
  height: 88rpx;
  font-size: 32rpx;
}
