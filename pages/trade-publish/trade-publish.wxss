/* 发布闲置页样式 */

.form-card {
  margin: 24rpx;
  padding: 8rpx 24rpx;
}

.form-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--ios-separator);
}

.form-item--last {
  border-bottom: none;
}

.form-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #1C1C1E;
  display: block;
  margin-bottom: 16rpx;
}

.form-required {
  color: var(--ios-red);
}

.form-input {
  font-size: 30rpx;
  color: #3A3A3C;
  height: 56rpx;
  line-height: 56rpx;
}

.form-price-input {
  display: flex;
  align-items: center;
}

.form-price-symbol {
  font-size: 30rpx;
  color: var(--ios-red);
  font-weight: 600;
  margin-right: 12rpx;
}

.form-textarea {
  font-size: 30rpx;
  color: #3A3A3C;
  width: 100%;
  height: 160rpx;
  line-height: 1.6;
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.form-picker-text {
  font-size: 30rpx;
  color: #3A3A3C;
}

.form-actions {
  display: flex;
  gap: 24rpx;
  margin: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.form-btn {
  flex: 1;
  height: 88rpx;
  font-size: 32rpx;
}
