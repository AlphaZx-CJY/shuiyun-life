<nav-bar title="缴费详情" showBack="{{true}}" />
<view class="page-container" wx:if="{{payment}}">
  <view class="detail-header">
    <text class="detail-tag">{{payment.tag}}</text>
    <text class="detail-title">{{payment.title}}</text>
    <view class="detail-meta">
      <text class="detail-date">更新于 {{payment.date}}</text>
    </view>
  </view>

  <view class="detail-content">
    <rich-text nodes="{{payment.content}}"></rich-text>
  </view>
</view>

<view class="empty-state" wx:else>
  <text class="empty-state__text">内容加载失败</text>
</view>
