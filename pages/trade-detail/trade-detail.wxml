<nav-bar title="商品详情" showBack="{{true}}" />
<view class="page-container" wx:if="{{trade}}">
  <!-- 图片区域 -->
  <view class="detail-gallery">
    <image wx:if="{{trade.images.length}}" class="detail-main-image" src="{{trade.images[0]}}" mode="aspectFill" bindtap="onImageTap" />
    <view wx:else class="detail-main-image detail-main-image--placeholder">
      <text class="detail-placeholder-text">🔄</text>
    </view>
  </view>

  <!-- 信息卡片 -->
  <view class="ios-card detail-info-card">
    <text class="detail-trade-title">{{trade.title}}</text>
    <view class="detail-price-row">
      <text class="detail-price">¥{{trade.price}}</text>
      <text class="detail-original">原价 ¥{{trade.originalPrice}}</text>
      <text class="discount-badge">{{trade.discount}}% off</text>
    </view>
    <view class="detail-meta-row">
      <text class="detail-meta-text">{{trade.seller}}</text>
      <text class="detail-meta-text">{{trade.location}}</text>
      <text class="detail-meta-text">{{trade.time}}</text>
    </view>
  </view>

  <!-- 描述卡片 -->
  <view class="ios-card detail-desc-card">
    <text class="detail-section-title">商品描述</text>
    <text class="detail-desc-text">{{trade.description}}</text>
  </view>

  <!-- 联系按钮 -->
  <view class="detail-action-bar">
    <view class="ios-btn ios-btn--primary detail-call-btn" bindtap="onCallTap">
      <text>联系卖家</text>
    </view>
  </view>
</view>

<view class="empty-state" wx:else>
  <text class="empty-state__text">商品信息加载失败</text>
</view>
