/* 交易详情页样式 */

.detail-gallery {
  padding: 24rpx 24rpx 0;
}

.detail-main-image {
  width: 100%;
  height: 500rpx;
  border-radius: var(--radius-md);
  background: var(--ios-bg);
}

.detail-main-image--placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--md-surface-variant) 0%, var(--md-surface) 100%);
}

.detail-placeholder-text {
  font-size: 120rpx;
}

.detail-info-card {
  margin: 24rpx;
  padding: 32rpx;
}

.detail-trade-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--md-on-surface);
  line-height: 1.4;
  display: block;
  margin-bottom: 20rpx;
}

.detail-price-row {
  display: flex;
  align-items: baseline;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.detail-price {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--md-primary);
}

.detail-original {
  font-size: 26rpx;
  color: var(--ios-light-gray);
  text-decoration: line-through;
}

.discount-badge {
  padding: 6rpx 16rpx;
  border-radius: var(--radius-pill);
  background: var(--md-surface-variant);
  color: var(--md-primary);
  font-size: 22rpx;
  font-weight: 600;
}

.detail-meta-row {
  display: flex;
  gap: 24rpx;
  flex-wrap: wrap;
}

.detail-meta-text {
  font-size: 24rpx;
  color: var(--ios-gray);
}

.detail-desc-card {
  margin: 0 24rpx 32rpx;
  padding: 32rpx;
}

.detail-section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--md-on-surface);
  display: block;
  margin-bottom: 16rpx;
}

.detail-desc-text {
  font-size: 28rpx;
  color: var(--md-on-surface-variant);
  line-height: 1.7;
  display: block;
}

.detail-action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: var(--wx-surface);
  border-top: 1rpx solid var(--wx-border);
}

.detail-call-btn {
  width: 100%;
  height: 88rpx;
  font-size: 32rpx;
}
