/* 使用指南详情页样式 */

.detail-header {
  padding: 32rpx 32rpx 24rpx;
}

.detail-tag {
  margin-bottom: 16rpx;
}

.detail-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--md-on-surface);
  line-height: 1.3;
  letter-spacing: -0.4rpx;
  margin-bottom: 16rpx;
}

.detail-date {
  display: block;
  font-size: 24rpx;
  color: var(--ios-gray);
}

.detail-content {
  margin: 0 24rpx 64rpx;
  padding: 48rpx 32rpx;
  font-size: 30rpx;
  line-height: 2.0;
  color: var(--wx-text);
  word-break: break-all;
}
