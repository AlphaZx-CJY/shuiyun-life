/* 使用指南详情页样式 */

.detail-header {
  padding: 40rpx 32rpx;
}

.detail-tag {
  margin-bottom: 20rpx;
  display: inline-flex;
  padding: 8rpx 16rpx;
  background: var(--md-primary-container);
  color: var(--md-on-primary-container);
  border-radius: var(--radius-xs);
  font-size: 22rpx;
  font-weight: 500;
}

.detail-title {
  font-size: 44rpx;
  font-weight: 600;
  color: var(--md-on-surface);
  line-height: 1.3;
  letter-spacing: -0.4rpx;
  display: block;
  margin-bottom: 20rpx;
}

.detail-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.detail-meta-dot {
  width: 4rpx;
  height: 4rpx;
  border-radius: 50%;
  background: var(--md-outline);
}

.detail-date {
  font-size: 24rpx;
  color: var(--md-on-surface-variant);
}

.detail-content {
  margin: 0 16rpx 64rpx;
  padding: 32rpx 24rpx;
  background: var(--md-surface-container-low);
  border-radius: var(--radius-md);
}

.detail-content rich-text {
  font-size: 32rpx;
  line-height: 1.75;
  color: var(--md-on-surface);
}
