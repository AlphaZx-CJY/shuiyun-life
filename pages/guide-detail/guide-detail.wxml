<nav-bar title="使用指南详情" showBack="{{true}}" />
<view class="page-container" wx:if="{{guide}}">
  <view class="detail-header">
    <text class="detail-tag">{{guide.tag}}</text>
    <text class="detail-title">{{guide.title}}</text>
    <view class="detail-meta">
      <text class="detail-date">更新于 {{guide.date}}</text>
    </view>
  </view>

  <view class="detail-content">
    <rich-text nodes="{{guide.content}}"></rich-text>
  </view>
</view>

<view class="empty-state" wx:else>
  <text class="empty-state__text">内容加载失败</text>
</view>
