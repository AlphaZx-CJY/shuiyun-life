/* 我的页面样式 */

.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 32rpx 48rpx;
  background: var(--ios-bg);
}

.profile-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #F5F5F7;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.12);
  overflow: hidden;
}

.profile-avatar-text {
  font-size: 80rpx;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #1D1D1F;
  margin-bottom: 8rpx;
}

.profile-address {
  font-size: 26rpx;
  color: var(--ios-gray);
}

.version-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx;
  gap: 8rpx;
}

.version-info text {
  font-size: 22rpx;
  color: var(--ios-light-gray);
}
