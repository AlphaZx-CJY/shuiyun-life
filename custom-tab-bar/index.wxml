<view class="tab-bar">
  <view class="tab-bar-item {{selected === index ? 'active' : ''}}"
    wx:for="{{list}}" wx:key="index"
    data-path="{{item.pagePath}}" data-index="{{index}}" bindtap="switchTab">
    <view class="tab-bar-indicator">
      <image class="tab-bar-icon tab-bar-icon--off" src="{{item.iconPath}}" mode="aspectFit"></image>
      <image class="tab-bar-icon tab-bar-icon--on" src="{{item.selectedIconPath}}" mode="aspectFit"></image>
    </view>
    <text class="tab-bar-text">{{item.text}}</text>
  </view>
</view>
