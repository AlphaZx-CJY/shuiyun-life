<view class="nav-bar" style="background: {{backgroundColor}};">
  <!-- 状态栏占位 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>
  
  <!-- 导航栏内容 -->
  <view class="nav-bar-content" style="height: {{navBarHeight}}px;">
    <!-- 返回按钮 -->
    <view wx:if="{{showBack}}" class="back-btn" style="top: {{menuButtonTop}}px; height: {{menuButtonHeight}}px;" bindtap="onBackTap">
      <view class="back-arrow"></view>
    </view>
    
    <!-- 标题 -->
    <view class="nav-title-wrapper">
      <text class="nav-title">{{title}}</text>
    </view>
  </view>
  
  <!-- 底部分割线 -->
  <view class="nav-border"></view>
</view>

<!-- 占位元素，防止内容被导航栏遮挡 -->
<view class="nav-placeholder" style="height: {{statusBarHeight + navBarHeight}}px;"></view>
