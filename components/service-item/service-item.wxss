.service-card {
  padding: 28rpx;
  margin-bottom: 16rpx;
}

.service-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.service-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.service-distance {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.service-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.service-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.service-info-item {
  display: flex;
}

.service-info-label {
  width: 120rpx;
  font-size: 24rpx;
  color: var(--ios-gray);
  flex-shrink: 0;
}

.service-info-value {
  flex: 1;
  font-size: 26rpx;
  color: #8E8E93;
}

.service-phone {
  color: #FFFFFF;
}
