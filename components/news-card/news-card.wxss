.news-card {
  display: flex;
  background: var(--ios-card);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
}

.news-card__content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.news-card__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.news-card__date {
  font-size: 22rpx;
  color: var(--ios-light-gray);
}

.news-card__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1C1C1E;
  line-height: 1.4;
  margin-bottom: 8rpx;
}

.news-card__summary {
  font-size: 26rpx;
  color: var(--ios-gray);
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.news-card__cover {
  width: 200rpx;
  height: 160rpx;
  border-radius: var(--radius-sm);
  margin-left: 20rpx;
  flex-shrink: 0;
  background: var(--ios-bg);
}
